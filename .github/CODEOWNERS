# Every file that gates publish, CI permissions, or release-pipeline
# trust requires @rowinbot review.
#
# A path-scoped branch ruleset on `main` enforces "require review from
# CODEOWNERS" on these paths; defense in depth versus a PR that silently
# adds an attacker username to a CODEOWNERS entry.

# Default reviewer for anything not otherwise matched.
* @rowinbot

# CI / workflows / Actions surface — write-access to any of these can
# pivot to OIDC publish abuse.
/.github/                           @rowinbot
/.github/CODEOWNERS                 @rowinbot
/.github/workflows/release.yml      @rowinbot
/.github/workflows/                 @rowinbot
/.github/dependabot.yml             @rowinbot

# Publish-side configuration — every line here is a Sigstore-trusted-publisher
# binding dependency.
/package.json                       @rowinbot
/pnpm-lock.yaml                     @rowinbot
/pnpm-workspace.yaml                @rowinbot
/.npmrc                             @rowinbot
/.npmignore                         @rowinbot
/LICENSE                            @rowinbot
/THIRD_PARTY_NOTICES.md             @rowinbot
/SECURITY.md                        @rowinbot

# Build + tooling baseline.
/tsconfig.json                      @rowinbot
/tsconfig.build.json                @rowinbot
/eslint.config.js                   @rowinbot
/.prettierrc.json                   @rowinbot
/.prettierignore                    @rowinbot
/.editorconfig                      @rowinbot
/.lockfile-lintrc.json              @rowinbot
/.depcheckrc.json                   @rowinbot
/.githooks/                         @rowinbot
/scripts/                           @rowinbot
