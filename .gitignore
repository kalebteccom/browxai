node_modules/
dist/
*.tsbuildinfo
coverage/
# Investigation artifacts (screenshots, profile JSONs) live under artifacts/
# and are regenerable via `pnpm exec vitest run --config vitest.investigation.config.ts`.
artifacts/
# VitePress build output + cache (any location)
.vitepress/dist/
.vitepress/cache/
# Transient state lives in $BROWX_WORKSPACE (~/.browxai/), NOT here. Guardrail
# entries below catch anything that would accidentally land in-tree.
.browxai/
.browx-profile/
.env
.env.*
# captured / managed browser session state — never commit
.auth/
.browx-profile/
*.storageState.json
# editor / OS cruft
.DS_Store
.idea/
.vscode/
*.log

# Raw client-named adopter/agent reports. The repo is public — raw reports
# (which may carry client / app / credential context) are NEVER tracked.
# Broad on purpose: any *-REPORT-*.md / REPORT-*.md / *-report.md /
# *-report-<date>.md at the repo ROOT is raw-until-handled. Sanitize the
# signal elsewhere; do not commit the raw file.
/*-REPORT-*.md
/REPORT-*.md
/*-report.md
/*-report-*.md
FIELD-REPORT-*.md
USAGE-REPORT-*.md
*-field-report.md
