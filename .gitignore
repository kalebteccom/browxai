# Astro + Starlight docs site (website/) build + generated artifacts.
website/dist/
website/.astro/
# The published ports are generated from the canonical docs/*.md by
# website/scripts/sync-docs.mjs at dev/build time. docs/ stays the single
# source of truth; do not commit or hand-edit the generated copies.
website/src/content/docs/reference/tool-reference.md
website/src/content/docs/security/threat-model.md
website/src/content/docs/security/best-practices.md
website/src/content/docs/plugins/overview.md
website/src/content/docs/plugins/first-party.md
website/src/content/docs/plugins/authoring.md
website/src/content/docs/plugins/governance.md
# Transient state lives in $BROWX_WORKSPACE (~/.browxai/), NOT here. Guardrail
# entries below catch anything that would accidentally land in-tree.
.browxai/
.browx-profile/
.env
.env.*
# captured / managed browser session state — never commit
.auth/
.browx-profile/
*.storageState.json
# editor / OS cruft
.DS_Store
.idea/
.vscode/
*.log

# Raw client-named adopter/agent reports. The repo is public — raw reports
# (which may carry client / app / credential context) are NEVER tracked.
# Broad on purpose: any *-REPORT-*.md / REPORT-*.md / *-report.md /
# *-report-<date>.md at the repo ROOT is raw-until-handled. Sanitize the
# signal elsewhere; do not commit the raw file.
/*-REPORT-*.md
/REPORT-*.md
/*-report.md
/*-report-*.md
FIELD-REPORT-*.md
USAGE-REPORT-*.md
*-field-report.md
