{
  "name": "@browxai/plugin-tldraw",
  "version": "0.1.0",
  "description": "Tldraw canvas-app adapter plugin for browxai — surfaces shapes/viewport/create/delete/select over the `window.editor` page-side global.",
  "author": "Kalebtec",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "browxai",
    "browxai-plugin",
    "tldraw",
    "canvas",
    "mcp",
    "browser-automation",
    "ai-agent"
  ],
  "homepage": "https://browxai.com/plugins/first-party/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kalebteccom/browxai.git",
    "directory": "packages/plugins/tldraw"
  },
  "bugs": {
    "url": "https://github.com/kalebteccom/browxai/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "schema.d.ts",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "browxai": {
    "apiVersion": "1.0.0",
    "browxaiVersion": "^0.7.0",
    "namespace": "tldraw",
    "register": "dist/index.js",
    "capabilities": [
      "eval",
      "canvas"
    ],
    "trust": "kalebtec",
    "dependsOn": []
  },
  "engines": {
    "node": ">=26"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
