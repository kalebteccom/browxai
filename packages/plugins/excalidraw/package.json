{
  "name": "@kalebtec/browxai-plugin-excalidraw",
  "version": "0.1.0",
  "description": "Excalidraw canvas-app adapter plugin for browxai — surfaces scene/viewport/add/delete/scroll over the `window.excalidrawAPI` page-side global.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "schema.d.ts",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "browxai": {
    "apiVersion": "1.0.0",
    "browxaiVersion": "^0.6.0",
    "namespace": "excalidraw",
    "register": "dist/index.js",
    "capabilities": ["eval", "canvas"],
    "trust": "kalebtec",
    "dependsOn": []
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
