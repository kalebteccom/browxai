{
  "name": "browxai",
  "version": "0.1.0",
  "private": true,
  "description": "MCP-native, model-agnostic, agentic-first browser-control server (Playwright/CDP).",
  "license": "MIT",
  "type": "module",
  "engines": { "node": ">=20" },
  "packageManager": "pnpm@9.0.0",
  "bin": { "browxai": "dist/cli.js" },
  "exports": { ".": "./dist/index.js" },
  "files": ["dist"],
  "scripts": {
    "prepublishOnly": "pnpm typecheck && pnpm test && pnpm build",
    "build": "tsc -p tsconfig.json && chmod +x dist/cli.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:keystone": "vitest run --config vitest.keystone.config.ts",
    "dev": "tsc -p tsconfig.json --watch",
    "browxai": "tsx src/cli.ts",
    "install-browser": "playwright-core install chromium"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "playwright-core": "^1.48.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
