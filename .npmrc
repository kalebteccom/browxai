# Repo-side dev install discipline.
#
# `ignore-scripts=true` blocks lifecycle scripts on `pnpm install` so a
# malicious transitive dep with a `postinstall` hook can't quietly own the
# dev host. The deliberate exception is browser-binary install — we ship
# `pnpm install-browser` (= `playwright-core install chromium`) as an
# explicit one-shot the contributor runs manually, NOT as a lifecycle.
#
# Sibling guideline: see SECURITY.md (sibling-owned) §dependency-hygiene.
ignore-scripts=true
