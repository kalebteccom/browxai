{
  "ignore-patterns": ["dist", "node_modules", "coverage", "artifacts", "packages/plugins/*/dist", "website/dist"],
  "ignores": [
    "@types/*",
    "tsx",
    "vitest",
    "@eslint/*",
    "eslint",
    "typescript-eslint",
    "eslint-plugin-import-x",
    "globals",
    "prettier",
    "lint-staged",
    "@cyclonedx/cyclonedx-npm",
    "license-checker-rseidelsohn",
    "depcheck"
  ],
  "skip-missing": false
}
